{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://windsor-api-mxxv.onrender.com/api/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://windsor-api-mxxv.onrender.com/api"
  }
}